{
  "name": "next-component-analyzer",
  "version": "0.1.0",
  "description": "CLI tool that analyzes Next.js components and suggests whether they should be Server or Client components.",
  "main": "dist/cli.js",
  "bin": {
    "next-component-analyzer": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsc && node dist/cli.js"
  },
  "keywords": [
    "nextjs",
    "next",
    "react",
    "component",
    "analyzer",
    "cli",
    "ast",
    "ts-morph"
  ],
  "author": "cinfinit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cinfinit/next-component-analyzer"
  },
  "bugs": {
    "url": "https://github.com/cinfinit/next-component-analyzer/issues"
  },
  "homepage": "https://github.com/cinfinit/next-component-analyzer#readme",
  "dependencies": {
    "fast-glob": "^3.3.1",
    "ts-morph": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/node": "^20.6.1"
  }
}